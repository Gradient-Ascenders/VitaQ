{
  "name": "vitaq",
  "version": "1.0.0",
  "description": "**VitaQ** is a web-based **Community Clinic Appointment & Queue System** designed to improve patient flow in public health clinics. It helps patients book appointments, join virtual queues remotely, and receive real-time updates, while giving clinic staff tools to manage queues and appointments more efficiently.",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "tw:build": "npx @tailwindcss/cli -i ./src/input.css -o ./frontend/assets/css/output.css",
    "tw:watch": "npx @tailwindcss/cli -i ./src/input.css -o ./frontend/assets/css/output.css --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gradient-Ascenders/VitaQ.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Gradient-Ascenders/VitaQ/issues"
  },
  "homepage": "https://github.com/Gradient-Ascenders/VitaQ#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "jest": "^30.3.0",
    "tailwindcss": "^4.2.2"
  }
}